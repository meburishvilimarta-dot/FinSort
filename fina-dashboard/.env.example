# --- Anthropic (required) -------------------------------------------------
# Server-side only; never shipped to the browser.
ANTHROPIC_API_KEY=
# Model used for all three endpoints (KPI parsing, web-search intel, suggestions).
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Drive (required for live KPIs) --------------------------------
# Create a Google Cloud service account, enable the Drive API, and share the
# "FINA-Marketing-Daily" folder with the service account's email (Viewer).
# Then EITHER paste the whole service-account key file as one line:
GOOGLE_SERVICE_ACCOUNT_JSON=
# ...OR set these two fields from it (private key with \n for newlines):
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Folder that receives the daily CSV/report exports.
DRIVE_FOLDER_NAME=FINA-Marketing-Daily
# Optional: pin the exact folder by ID instead of searching by name.
DRIVE_FOLDER_ID=

# --- Tuning (optional) -----------------------------------------------------
# Timezone used to decide whether "today's" report has arrived yet.
DASHBOARD_TIMEZONE=Asia/Tbilisi
# How long results are reused before re-fetching (per warm server instance).
KPIS_CACHE_MINUTES=10
INTEL_CACHE_MINUTES=45
