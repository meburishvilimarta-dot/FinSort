# In Framer: open the project -> Cmd+K -> "open settings" -> API Keys section
# -> create a key. It is bound to this one project.
FRAMER_API_KEY=

# The Framer *project* URL, not the published site domain, e.g.
# https://framer.com/projects/Website--aabbccdd1122
FRAMER_PROJECT_URL=

# Name of the CMS collection to publish into.
FRAMER_COLLECTION_NAME=Journal
