# In Framer: open the project -> Cmd+K -> "open settings" -> API Keys section
# -> create a key. It is bound to this one project.
FRAMER_API_KEY=

# The Framer *project* URL, not the published site domain, e.g.
# https://framer.com/projects/Website--aabbccdd1122
FRAMER_PROJECT_URL=

# Name of the CMS collection to publish into.
FRAMER_COLLECTION_NAME=Journal

# --- fina2.net pipeline ---
# By explicit choice this currently REUSES the FRAMER_API_KEY /
# FRAMER_PROJECT_URL secrets above (set to fina2.net's key/URL) instead of
# separate secrets — see .github/workflows/fina2-*.yml. That means only one
# of the two Framer projects (Maison Metekhi vs fina2.net) can be live in
# those secrets at a time. For local runs, set these two to fina2.net's own
# values (they don't have to match FRAMER_API_KEY/FRAMER_PROJECT_URL locally,
# only the GitHub Actions secrets are shared):

# API key created on the fina2.net Framer project.
FINA2_FRAMER_API_KEY=

# The fina2.net Framer *project* URL, e.g.
# https://framer.com/projects/fina2-net-MAIN-12-Jan-2026--5ZVvVLpwiWjL5HFcTkB7-3otVM
FINA2_FRAMER_PROJECT_URL=

# Name of the blog CMS collection to publish into (confirmed via
# check-connection.mjs).
FINA2_FRAMER_COLLECTION_NAME=Blogs
