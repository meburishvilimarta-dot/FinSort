# In Framer: open the project -> Cmd+K -> "open settings" -> API Keys section
# -> create a key. It is bound to this one project.
FRAMER_API_KEY=

# The Framer *project* URL, not the published site domain, e.g.
# https://framer.com/projects/Website--aabbccdd1122
FRAMER_PROJECT_URL=

# Name of the CMS collection to publish into.
FRAMER_COLLECTION_NAME=Journal

# --- fina2.net pipeline (separate Framer project, kept independent of the
# Maison Metekhi vars above) ---

# API key created on the fina2.net Framer project.
FINA2_FRAMER_API_KEY=

# The fina2.net Framer *project* URL, e.g.
# https://framer.com/projects/fina2-net-MAIN-12-Jan-2026--5ZVvVLpwiWjL5HFcTkB7-3otVM
FINA2_FRAMER_PROJECT_URL=

# Name of the blog CMS collection to publish into. Not known yet — leave
# blank, run `npm run fina2:check-connection` to list the project's
# collections, then fill this in.
FINA2_FRAMER_COLLECTION_NAME=
